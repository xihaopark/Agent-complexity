AGENTIC_ENV=dev
AGENTIC_DATABASE_URL=postgresql+psycopg://agentic:agentic@postgres:5432/agentic
AGENTIC_REDIS_URL=redis://redis:6379/0
AGENTIC_SECRET_KEY=change-this-in-production
AGENTIC_ARTIFACT_ROOT=/app/data/artifacts
AGENTIC_STORAGE_MODE=filesystem
AGENTIC_COMPOSITE_SCORE_ENABLED=false
AGENTIC_DEFAULT_REPEATS=10
AGENTIC_DEFAULT_TIMEOUT_SEC=1800
AGENTIC_MAX_REPEATS=10
AGENTIC_STANDARD_CPUS=2
AGENTIC_STANDARD_MEMORY_MB=4096
AGENTIC_STANDARD_PIDS_LIMIT=512
AGENTIC_STANDARD_CONCURRENCY=3
AGENTIC_DOCKER_IMAGE=python:3.11-slim
AGENTIC_DOCKER_NETWORK=bridge
AGENTIC_OTEL_EXPORTER_ENDPOINT=http://otel-gateway:4318
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
