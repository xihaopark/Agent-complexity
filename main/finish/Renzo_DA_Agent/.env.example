# -----------------------------------------------------------------------------
# Renzo runtime defaults (copy to .env and adjust per environment)
# -----------------------------------------------------------------------------

# Docker: bind address and host ports (for external access use BIND_IP=0.0.0.0)
# BIND_IP=0.0.0.0  = listen on all interfaces (LAN/WAN). Use server IP in URL.
# BIND_IP=127.0.0.1 = local only.
BIND_IP=0.0.0.0
BACKEND_PORT=18000
FRONTEND_PORT=13000

# Local dev entrypoints (used by start_local.sh and daemon scripts)
LOCAL_BACKEND_PORT=8000
LOCAL_FRONTEND_PORT=5173
VITE_PROXY_TARGET=http://127.0.0.1:8000

# Workflow runtime strategy
# 1 = allow runtime install; 0 = fail fast if engine is missing
WORKFLOW_RUNTIME_INSTALL=1
NEXTFLOW_VERSION=24.10.5
SNAKEMAKE_VERSION=8.30.0
WORKFLOW_SNAKEMAKE_ENV=snakemake
WORKFLOW_RUNTIME_CACHE_DIR=/app/data/cache/runtime

# Optional absolute path when conda is not already on PATH.
# Useful in remote sandboxes where the shared Snakemake env exists but PATH is minimal.
# CONDA_EXE=/root/miniconda3/bin/conda

# Data root (Docker sets DATA_ROOT=/app/data so datasets/experiments use mounted ./data)
# Omit for local dev (defaults to project data/). Set if you run backend with data elsewhere.
# DATA_ROOT=/app/data

# Integration paths inside backend container
WORKFLOW_POOL_DIR=/app/workflow_pool

# Conversation / control plane flags
SHELL_ENABLED=true
SHELL_FALLBACK_RULES=true
UNIFIED_CONTROLLER_ENABLED=true
TOP_CONTROLLER_LLM_ENABLED=true
