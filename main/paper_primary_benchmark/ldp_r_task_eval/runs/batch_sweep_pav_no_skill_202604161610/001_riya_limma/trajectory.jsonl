he contrasts\\nfit2 <- contrasts.fit(fit, contrast.matrix)\\nfit2 <- eBayes(fit2)\\n\\n# Get top 250 differentially expressed genes\\ndeg_results <- topTable(fit2, number=250, sort.by='P')\\n\\n# Write results to CSV\\nwrite.csv(deg_results, 'output/deg_results.csv')\\n\\n# Generate a volcano plot\\nvolcanoplot(fit2, highlight=250, names=rownames(gene_expression))\\ndev.copy(png, 'output/volcano.png')\\ndev.off()\\n\"}", "name": "write_text_file"}}]}], "hide_old_env_states": false, "hide_old_action_content": false}, "next_agent_state": {"tools": [{"type": "function", "info": {"name": "run_shell", "description": "Run a shell command in the task work_dir (bash -lc).", "parameters": {"type": "object", "properties": {"command": {"description": "Shell command string passed to `bash -lc`.", "title": "Command", "type": "string"}}, "required": ["command"]}}}, {"type": "function", "info": {"name": "read_text_file", "description": "Read a UTF-8 text file relative to work_dir.", "parameters": {"type": "object", "properties": {"relative_path": {"description": "Path under the workspace (not absolute).", "title": "Relative Path", "type": "string"}}, "required": ["relative_path"]}}}, {"type": "function", "info": {"name": "write_text_file", "description": "Write text to a path under work_dir (creates parent dirs).", "parameters": {"type": "object", "properties": {"relative_path": {"description": "Path under the workspace (not absolute).", "title": "Relative Path", "type": "string"}, "content": {"description": "Full file body to write as UTF-8 text.", "title": "Content", "type": "string"}}, "required": ["relative_path", "content"]}}}, {"type": "function", "info": {"name": "run_rscript", "description": "Run inline R code via Rscript -e (single line safe for agents).", "parameters": {"type": "object", "properties": {"code": {"description": "R expression passed as the argument to `Rscript -e`.", "title": "Code", "type": "string"}}, "required": ["code"]}}}, {"type": "function", "info": 