ure <- extract_feature(sampleC$Annotation)\\n\\n# Count features\\ncount_features <- function(data) {\\n  data %>% count(Feature)\\n}\\n\\ncountA <- count_features(sampleA)\\ncountB <- count_features(sampleB)\\ncountC <- count_features(sampleC)\\n\\n# Create summary table\\nsummary_table <- full_join(countA, countB, by = 'Feature', suffix = c('_A', '_B')) %>%\\n  full_join(countC, by = 'Feature') %>%\\n  rename(Count_C = n) %>%\\n  replace_na(list(n_A = 0, n_B = 0, Count_C = 0))\\n\\nwrite_tsv(summary_table, 'output/homer_annot_summary.tsv')\\n\\n# Plotting\\n# Feature proportion barplot\\nfeature_data <- summary_table %>% gather(Sample, Count, -Feature)\\nfeature_plot <- ggplot(feature_data, aes(x = Feature, y = Count, fill = Sample)) +\\n  geom_bar(stat = 'identity', position = 'fill') +\\n  theme(axis.text.x = element_text(angle = 90, hjust = 1)) +\\n  labs(title = 'Feature Proportion')\\n\\n# Distance bin barplot\\nbin_data <- bind_rows(\\n  sampleA %>% mutate(Sample = 'A'),\\n  sampleB %>% mutate(Sample = 'B'),\\n  sampleC %>% mutate(Sample = 'C')\\n) %>%\\n  mutate(DistanceBin = cut(abs(`Distance to TSS`), breaks = c(-Inf, 2000, 5000, 10000, Inf),\\n                           labels = c('<2kb', '<5kb', '<10kb', '>10kb')))\\n\\nbin_plot <- ggplot(bin_data, aes(x = DistanceBin, fill = Sample)) +\\n  geom_bar(position = 'fill') +\\n  labs(title = 'Distance Bin Proportion')\\n\\n# Violin plot\\nviolin_plot <- ggplot(bin_data, aes(x = Sample, y = log10(abs(`Distance to TSS`)))) +\\n  geom_violin() +\\n  labs(title = 'Log10 Distance to TSS')\\n\\n# Save plots to PDF\\npdf('output/homer_annot.pdf')\\ngrid.arrange(feature_plot, bin_plot, violin_plot, ncol = 1)\\ndev.off()\"}", "name": "run_rscript"}}]}, {"role": "tool", "content": "exit=0\nstdout:\nnull device \n          1 \n\nstderr:\n\nAttaching package: \u2018dplyr\u2019\n\nThe following objects are masked from \u2018package:stats\u2019:\n\n    filter, lag\n\nThe following objects are masked from \u2018package:bas