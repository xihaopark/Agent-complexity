: {"tools": [{"type": "function", "info": {"name": "run_shell", "description": "Run a shell command in the task work_dir (bash -lc).", "parameters": {"type": "object", "properties": {"command": {"description": "Shell command string passed to `bash -lc`.", "title": "Command", "type": "string"}}, "required": ["command"]}}}, {"type": "function", "info": {"name": "read_text_file", "description": "Read a UTF-8 text file relative to work_dir.", "parameters": {"type": "object", "properties": {"relative_path": {"description": "Path under the workspace (not absolute).", "title": "Relative Path", "type": "string"}}, "required": ["relative_path"]}}}, {"type": "function", "info": {"name": "write_text_file", "description": "Write text to a path under work_dir (creates parent dirs).", "parameters": {"type": "object", "properties": {"relative_path": {"description": "Path under the workspace (not absolute).", "title": "Relative Path", "type": "string"}, "content": {"description": "Full file body to write as UTF-8 text.", "title": "Content", "type": "string"}}, "required": ["relative_path", "content"]}}}, {"type": "function", "info": {"name": "run_rscript", "description": "Run inline R code via Rscript -e (single line safe for agents).", "parameters": {"type": "object", "properties": {"code": {"description": "R expression passed as the argument to `Rscript -e`.", "title": "Code", "type": "string"}}, "required": ["code"]}}}, {"type": "function", "info": {"name": "list_workdir", "description": "List workspace as JSON (bounded depth).", "parameters": {"type": "object", "properties": {}, "required": []}}}, {"type": "function", "info": {"name": "write_plan", "description": "Persist a markdown plan to `workspace/.plan.md` (overwrite on rewrite).\n\nUse this at the start of a task and whenever the plan needs revision. The\nplan is not shown automatically on later steps; call check_progress to see\nthe current plan excerpt alongside deliverable state.", "parameters": {"type": "object", "pro