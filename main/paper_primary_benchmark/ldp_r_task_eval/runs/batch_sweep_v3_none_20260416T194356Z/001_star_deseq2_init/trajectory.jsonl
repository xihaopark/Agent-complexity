)\\n\\n# Relevel the condition factor\\ndds$condition <- relevel(dds$condition, ref = 'untreated')\\n\\n# Run DESeq\\ndds <- DESeq(dds)\\n\\n# Save the DESeq2 object\\nsaveRDS(dds, 'output/dds.rds')\\n\\n# Get normalized counts\\nnormalized_counts <- counts(dds, normalized=TRUE)\\n\\n# Write normalized counts to file\\nwrite.table(as.data.frame(normalized_counts), file='output/normalized_counts.tsv', sep='\\\\t', row.names=TRUE, col.names=NA)\"}", "name": "run_rscript"}}]}, "logprob": null}, "reward": 0.0, "truncated": false, "done": false, "value": 0.0, "metadata": {}}
