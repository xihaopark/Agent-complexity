le == sample) %>% pull(Replicate)\\n  \\n  # Compute average across replicates\\n  genecount_avg <- genecount %>% \\n    select(GID, all_of(replicate_cols)) %>% \\n    rowwise() %>% \\n    mutate(avg = mean(c_across(all_of(replicate_cols)))) %>% \\n    select(GID, avg)\\n  \\n  # Join with ref_genes\\n  joined_data <- genecount_avg %>% \\n    inner_join(ref_genes, by='GID')\\n  \\n  # Calculate RPKM\\n  joined_data <- joined_data %>% \\n    mutate(RPKM = avg * 1000 / (V3 - V2)) %>% \\n    select(GID, Sample=sample, RPKM)\\n  \\n  # Accumulate results\\n  all_rpkm <- bind_rows(all_rpkm, joined_data)\\n}\\n\\n# Write the result to file\\nwrite.table(all_rpkm, 'output/results/RNA/DEG/genes_rpkm__runX__mockref.txt', sep='\\\\t', row.names=FALSE, col.names=TRUE, quote=FALSE)\"}", "name": "run_rscript"}}]}, {"role": "tool", "content": "exit=1\nstdout:\n\nstderr:\n\nAttaching package: \u2018dplyr\u2019\n\nThe following objects are masked from \u2018package:stats\u2019:\n\n    filter, lag\n\nThe following objects are masked from \u2018package:base\u2019:\n\n    intersect, setdiff, setequal, union\n\nError in `select()`:\n! Can't select columns that don't exist.\n\u2716 Column `WT` doesn't exist.\nBacktrace:\n     \u2586\n  1. \u251c\u2500... %>% select(GID, Sample = sample, RPKM)\n  2. \u251c\u2500dplyr::select(., GID, Sample = sample, RPKM)\n  3. \u251c\u2500dplyr:::select.data.frame(., GID, Sample = sample, RPKM)\n  4. \u2502 \u2514\u2500tidyselect::eval_select(expr(c(...)), data = .data, error_call = error_call)\n  5. \u2502   \u2514\u2500tidyselect:::eval_select_impl(...)\n  6. \u2502     \u251c\u2500tidyselect:::with_subscript_errors(...)\n  7. \u2502     \u2502 \u2514\u2500base::withCallingHandlers(...)\n  8. \u2502     \u2514\u2500tidyselect:::vars_select_eval(...)\n  9. \u2502       \u2514\u2500tidyselect:::walk_data_tree(expr, data_mask, context_mask)\n 10. \u2502         \u2514\u2500tidyselect:::eval_c(expr, data_mask, context_mask)\n 11. \u2502           \u2514\u