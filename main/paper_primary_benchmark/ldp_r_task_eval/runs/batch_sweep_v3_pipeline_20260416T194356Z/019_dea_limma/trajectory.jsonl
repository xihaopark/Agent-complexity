6iJ", "type": "function", "function": {"arguments": "{\"code\": \"library(limma)\\nlibrary(edgeR)\\nlibrary(statmod)\\nlibrary(data.table)\\n\\n# Load data\\ndata <- data.frame(fread('input/counts.tsv', header=TRUE), row.names=1)\\nmetadata <- data.frame(fread('input/metadata.tsv', header=TRUE, na.strings=c('NA', '')), row.names=1)\\n\\n# Prepare DEA\\ndesign <- model.matrix(~treatment, metadata)\\ndge <- DGEList(data, samples=metadata, genes=rownames(data))\\ndge <- calcNormFactors(dge, method='TMM')\\nv <- voom(dge, design, plot=FALSE)\\n\\n# Fit linear model\\nlmfit <- lmFit(v, design)\\nlmfit <- eBayes(lmfit, robust=TRUE)\\n\\n# Extract results\\ndea_results <- topTable(lmfit, coef='treatmentTR', number=nrow(data), sort.by='P')\\n\\n# Add group column\\ndea_results$group <- ifelse(dea_results$logFC > 0, 'TR', 'UT')\\n\\n# Save results\\nfwrite(dea_results, 'output/dea_results.csv')\\n\\n# Save fitted model\\nsaveRDS(lmfit, 'output/lmfit.rds')\\n\\n# Save design matrix\\nfwrite(design, 'output/model_matrix.csv', row.names=TRUE)\"}", "name": "run_rscript"}}]}], "hide_old_env_states": false, "hide_old_action_content": false}, "next_agent_state": {"tools": [{"type": "function", "info": {"name": "run_shell", "description": "Run a shell command in the task work_dir (bash -lc).", "parameters": {"type": "object", "properties": {"command": {"description": "Shell command string passed to `bash -lc`.", "title": "Command", "type": "string"}}, "required": ["command"]}}}, {"type": "function", "info": {"name": "read_text_file", "description": "Read a UTF-8 text file relative to work_dir.", "parameters": {"type": "object", "properties": {"relative_path": {"description": "Path under the workspace (not absolute).", "title": "Relative Path", "type": "string"}}, "required": ["relative_path"]}}}, {"type": "function", "info": {"name": "write_text_file", "description": "Write text to a path under work_dir (creates parent dirs).", "parameters": {"type": "object", "properties": {"relati