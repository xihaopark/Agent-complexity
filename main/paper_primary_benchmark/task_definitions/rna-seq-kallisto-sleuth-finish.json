{
  "workflow_id": "rna-seq-kallisto-sleuth-finish",
  "manifest_path": "finish/rna-seq-kallisto-sleuth-finish/manifest.json",
  "version": "1",
  "updated_at": "2026-04-16",
  "notes": "Reference partition: config/inputs → references & reads → quantification → DE & reporting. step_snapshots copied from finish manifest for offline review.",
  "tasks": [
    {
      "task_id": "setup_config_and_inputs",
      "pipeline_stage_label": "配置校验与输入规范化",
      "order": 1,
      "step_ids": ["validate_config", "normalize_inputs"],
      "metadata": {
        "summary": "Validate YAML/samples/units and normalize metadata paths."
      },
      "inputs": [
        {
          "role": "workflow_config",
          "path_glob": "config_basic/config.yaml",
          "description": "Finish step-split config driving Snakemake."
        },
        {
          "role": "samplesheet",
          "path_glob": "config_basic/samples.tsv"
        },
        {
          "role": "units",
          "path_glob": "config_basic/units.tsv"
        }
      ],
      "outputs": [
        {
          "role": "checkpoint",
          "path_glob": "results/finish/normalize_inputs.done",
          "derived_from_step_ids": ["normalize_inputs"]
        }
      ],
      "step_snapshots": [
        {
          "id": "validate_config",
          "name": "Validate workflow configuration",
          "outputs": ["results/finish/validate_config.done"],
          "depends_on": []
        },
        {
          "id": "normalize_inputs",
          "name": "Normalize metadata and workflow inputs",
          "outputs": ["results/finish/normalize_inputs.done"],
          "depends_on": ["validate_config"]
        }
      ]
    },
    {
      "task_id": "references_and_reads",
      "pipeline_stage_label": "参考序列与读段准备",
      "order": 2,
      "step_ids": ["prepare_references", "prepare_reads"],
      "metadata": {
        "summary": "Build kallisto index resources and prepare reads for quantification."
      },
      "inputs": [
        {
          "role": "normalized_config",
          "description": "Uses config after normalize_inputs",
          "derived_from_step_ids": ["normalize_inputs"]
        }
      ],
      "outputs": [
        {
          "role": "reference_artifacts",
          "path_glob": "resources/transcriptome.cdna.fasta",
          "derived_from_step_ids": ["prepare_references"]
        },
        {
          "role": "read_prep_checkpoint",
          "path_glob": "results/finish/prepare_reads.done",
          "derived_from_step_ids": ["prepare_reads"]
        }
      ],
      "step_snapshots": [
        {
          "id": "prepare_references",
          "name": "Prepare kallisto references",
          "outputs": ["results/finish/prepare_references.done"],
          "depends_on": ["normalize_inputs"]
        },
        {
          "id": "prepare_reads",
          "name": "Prepare reads for quantification",
          "outputs": ["results/finish/prepare_reads.done"],
          "depends_on": ["prepare_references"]
        }
      ]
    },
    {
      "task_id": "quantify_and_init_sleuth",
      "pipeline_stage_label": "定量与 sleuth 初始化",
      "order": 3,
      "step_ids": ["quantify", "init_sleuth"],
      "metadata": {
        "summary": "Kallisto quantification then sleuth object inputs."
      },
      "inputs": [
        {
          "role": "prepared_reads",
          "derived_from_step_ids": ["prepare_reads"]
        }
      ],
      "outputs": [
        {
          "role": "sleuth_init",
          "path_glob": "results/sleuth/all.samples.tsv",
          "derived_from_step_ids": ["init_sleuth"]
        }
      ],
      "step_snapshots": [
        {
          "id": "quantify",
          "name": "Run kallisto quantification",
          "outputs": ["results/finish/quantify.done"],
          "depends_on": ["prepare_reads"]
        },
        {
          "id": "init_sleuth",
          "name": "Initialize sleuth model inputs",
          "outputs": ["results/finish/init_sleuth.done"],
          "depends_on": ["quantify"]
        }
      ]
    },
    {
      "task_id": "de_analysis_and_delivery",
      "pipeline_stage_label": "差异分析与交付报告",
      "order": 4,
      "step_ids": ["differential_expression", "optional_modules", "delivery_report"],
      "metadata": {
        "summary": "Sleuth DE, optional modules, final HTML/report delivery."
      },
      "inputs": [
        {
          "role": "sleuth_tables",
          "derived_from_step_ids": ["init_sleuth"]
        }
      ],
      "outputs": [
        {
          "role": "diffexp",
          "path_glob": "results/diffexp/*",
          "derived_from_step_ids": ["differential_expression"]
        },
        {
          "role": "report",
          "path_glob": "results/datavzrd/*/index.html",
          "derived_from_step_ids": ["delivery_report"]
        }
      ],
      "step_snapshots": [
        {
          "id": "differential_expression",
          "name": "Run sleuth differential expression",
          "outputs": ["results/finish/differential_expression.done"],
          "depends_on": ["init_sleuth"]
        },
        {
          "id": "optional_modules",
          "name": "Run optional comparison modules",
          "outputs": ["results/finish/optional_modules.done"],
          "depends_on": ["differential_expression"]
        },
        {
          "id": "delivery_report",
          "name": "Assemble final delivery report",
          "outputs": ["results/finish/delivery_report.done"],
          "depends_on": ["optional_modules"]
        }
      ]
    }
  ]
}
