configfile: "config.yaml"

rule all:
    input:
        config["output_file"],
        config["summary_file"]

rule copy_input:
    input:
        config["input_file"]
    output:
        config["output_file"]
    shell:
        "cp {input} {output}"

rule summarize_output:
    input:
        config["output_file"]
    output:
        config["summary_file"]
    run:
        import hashlib
        import json
        from pathlib import Path

        text = Path(input[0]).read_text(encoding="utf-8")
        payload = {
            "char_count": len(text),
            "line_count": len(text.splitlines()),
            "output_file": str(input[0]),
            "sha256": hashlib.sha256(text.encode("utf-8")).hexdigest(),
        }
        Path(output[0]).write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
