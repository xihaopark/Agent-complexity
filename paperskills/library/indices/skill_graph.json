  "discovery_rules": {
    "scenario_to_skills": {
      "rna_de_analysis": {
        "description": "Differential expression analysis of RNA-seq data",
        "relevant_skills": ["10.1186/s13059-014-0550-8", "10.1093/nar/gkv007"],
        "decision_guide": "Use DESeq2 for count-based analysis with built-in normalization. Use limma+voom if you need flexible designs or have quality variations."
      },
      "scrna_analysis": {
        "description": "Single-cell RNA-seq analysis",
        "relevant_skills": ["10.1101/2020.10.12.335331"],
        "decision_guide": "Start with Seurat for comprehensive workflow. Consider SCTransform for normalization."
      },
      "chip_peak_calling": {
        "description": "ChIP-seq peak calling",
        "relevant_skills": ["10.1186/gb-2008-9-9-r137"],
        "decision_guide": "Use MACS2. Choose --broad for histone marks, narrow for TFs."
      },
      "small_sample_rna": {
        "description": "RNA-seq with very few replicates",
        "relevant_skills": ["10.1186/s13059-014-0550-8"],
        "decision_guide": "Use DESeq2 with type='apeglm' in lfcShrink() for stable estimates with n<5 per group."
      },
      "paired_design_rna": {
        "description": "Paired or matched RNA-seq samples",
        "relevant_skills": ["10.1093/nar/gkv007"],
        "decision_guide": "Use limma with duplicateCorrelation() to properly model within-subject correlation."
      },
      "batch_correction_needed": {
        "description": "RNA-seq with known batch effects",
        "relevant_skills": ["TBD_sva"],
        "decision_guide": "NEEDS SKILL: sva/ComBat-seq for count-based batch correction."
      }
    }
  }
